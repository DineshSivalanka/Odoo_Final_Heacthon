{
  "info": {
    "name": "Mini ERP - Shiv Furniture Works",
    "description": "Complete API collection for Mini ERP system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔍 Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shivfurniture.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dinesh\",\n  \"email\": \"dinesh@shivfurniture.com\",\n  \"password\": \"password123\",\n  \"role\": \"SALES\"\n}"
            }
          }
        },
        {
          "name": "Get Me (requires token)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/1"
          }
        },
        {
          "name": "Create Product (Raw Material)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teak Wood\",\n  \"description\": \"Raw teak wood planks\",\n  \"sales_price\": 0,\n  \"cost_price\": 500,\n  \"procurement_type\": \"PURCHASE\",\n  \"procurement_strategy\": \"MTS\"\n}"
            }
          }
        },
        {
          "name": "Create Product (Finished Good)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wooden Chair\",\n  \"description\": \"Handcrafted teak chair\",\n  \"sales_price\": 3500,\n  \"cost_price\": 1500,\n  \"procurement_type\": \"MANUFACTURING\",\n  \"procurement_strategy\": \"MTS\"\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teak Wood\",\n  \"description\": \"Premium raw teak wood planks\",\n  \"sales_price\": 0,\n  \"cost_price\": 550,\n  \"procurement_type\": \"PURCHASE\",\n  \"procurement_strategy\": \"MTS\"\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/1"
          }
        },
        {
          "name": "Add BoM to Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products/2/bom",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"components\": [\n    { \"component_id\": 1, \"quantity\": 5 }\n  ],\n  \"operations\": [\n    { \"operation_name\": \"Cutting\", \"duration\": 30 },\n    { \"operation_name\": \"Polishing\", \"duration\": 60 }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Sales Orders",
      "item": [
        {
          "name": "Get All Sales Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/sales"
          }
        },
        {
          "name": "Get Sales Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/sales/1"
          }
        },
        {
          "name": "Create Sales Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/sales",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_name\": \"Ramesh Furniture Store\",\n  \"items\": [\n    { \"product_id\": 2, \"quantity\": 3 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Confirm Sales Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/sales/1/confirm"
          }
        },
        {
          "name": "Deliver Sales Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/sales/1/deliver"
          }
        },
        {
          "name": "Cancel Sales Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/sales/1/cancel"
          }
        }
      ]
    },
    {
      "name": "🏭 Purchase Orders",
      "item": [
        {
          "name": "Get All Purchase Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/purchase"
          }
        },
        {
          "name": "Get Purchase Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/purchase/1"
          }
        },
        {
          "name": "Create Purchase Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/purchase",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vendor_name\": \"Wood Supplier Co.\",\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 100 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Confirm Purchase Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/purchase/1/confirm"
          }
        },
        {
          "name": "Receive Purchase Order (Adds Stock)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/purchase/1/receive"
          }
        },
        {
          "name": "Cancel Purchase Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/purchase/1/cancel"
          }
        }
      ]
    },
    {
      "name": "⚙️ Manufacturing Orders",
      "item": [
        {
          "name": "Get All Manufacturing Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/manufacturing"
          }
        },
        {
          "name": "Get Manufacturing Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/manufacturing/1"
          }
        },
        {
          "name": "Create Manufacturing Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/manufacturing",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 2,\n  \"quantity\": 10\n}"
            }
          }
        },
        {
          "name": "Start Manufacturing Order (Consumes Materials)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/manufacturing/1/start"
          }
        },
        {
          "name": "Complete Manufacturing Order (Adds Finished Goods)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/manufacturing/1/complete"
          }
        },
        {
          "name": "Cancel Manufacturing Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/manufacturing/1/cancel"
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Full Dashboard Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard"
          }
        },
        {
          "name": "Inventory List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard/inventory"
          }
        },
        {
          "name": "Stock Ledger (All Movements)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/dashboard/stock-ledger"
          }
        }
      ]
    }
  ]
}
